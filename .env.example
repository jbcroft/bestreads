# Database
DATABASE_URL=postgresql+asyncpg://booktracker:booktracker@postgres:5432/booktracker

# Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic (optional — recommendations degrade gracefully if unset)
ANTHROPIC_API_KEY=

# Covers
COVERS_DIR=/app/covers

# MCP server → FastAPI
API_BASE_URL=http://fastapi:8000/api/v1
BOOK_TRACKER_API_KEY=
